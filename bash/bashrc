#!/usr/bin/bash

# .bashrc

OLDHOME=$HOME
HOME=$(readlink -e $HOME)
if [ "$HOME" != "$OLDHOME" ]; then
    echo "OLDHOME: $OLDHOME"
else
    unset OLDHOME
fi

# Source global definitions
if [ -f /etc/bashrc ]; then
    source /etc/bashrc
fi

remove_from_PATH() {
    PATH=$(echo $PATH | sed -e s"%$1:%%" -e s"%:$1$%%")
}

add_to_path() {
    [ ! -d "$1" ] && return

    case ":${PATH}:" in
        *:"$1":*)
            ;;
        *)
            if [ "$2" = "before" ] ; then
                PATH=$1:$PATH
            else
                PATH=$PATH:$1
            fi
    esac
}

# exit if non-interactive (no stdin)
[ ! -t 0 ] && return 0

############### below is for interactive shell only ###########################

# if [ "${-#*i}" != "$-" ]; then
#     echo -e "default prompt: ${PS1@P}"
# fi

eval $(grep "\(^ID=\|VERSION_ID\|VARIANT_ID\|ANSI_COLOR\)" /etc/os-release)

if [ -n "$container" ]; then
export HISTFILE="${HOME}/.bash_history.tb.${ID}${VERSION_ID}.${TERM}"
fi

## avoid systemctl auto-paging
# export SYSTEMD_PAGER=

# dont cache command locations
set +h

# User specific aliases and functions
alias ls='ls --color=auto'

vterm_printf(){
    if [ -n "$TMUX" ] && ([ "${TERM%%-*}" = "tmux" ] || [ "${TERM%%-*}" = "screen" ] ); then
        # Tell tmux to pass the escape sequences through
        printf "\ePtmux;\e\e]%s\007\e\\" "$1"
    elif [ "${TERM%%-*}" = "screen" ]; then
        # GNU screen (screen, screen-256color, screen-256color-bce)
        printf "\eP\e]%s\007\e\\" "$1"
    else
        printf "\e]%s\e\\" "$1"
    fi
}

# for prompt and directory tracking
# was "51;A$(whoami)@$(hostname):$(pwd)"
emacs_term_send_dir(){
    case "$INSIDE_EMACS" in
        vterm) vterm_printf "51;A$PWD" ;;
        *,eat) vterm_printf "51;e;A;$(echo "$PWD" | base64)" ;;
    esac
}

# Bash Color Prompt
source ~/github/bash-color-prompt/bash-color-prompt.sh

# Function to get the parent command name
bcp_subshell() {
    # IN_NIX_SHELL only for legacy impure nix: was [[ -n "$IN_NIX_SHELL" ||
    # can switch to /nix/store/* once nix.sh only sources once
    if [[ "$PATH" == *:/nix/store/* ]]; then
        bcp_append "❄️ "
    elif [[ "$SHLVL" -gt 1 && -z "$INSIDE_EMACS" || "$SHLVL" -gt 2 ]]; then
        # output the command name without headers
        local parent_cmd=$(ps -p $PPID -o comm= 2>/dev/null)
        if [ -n "$parent_cmd" ]; then
            bcp_append "$parent_cmd " "yellow"
        fi
    fi
}

bcp_layout() {
    local exit_code=$1

    bcp_duration 1 "yellow" "took " "\n"

    bcp_append "\t \D{%b %-d (%a)}" "dim;reverse"
    if [[ $exit_code -ne 0 ]]; then
        bcp_append " [$exit_code]" "red"
    fi
    bcp_append "\n"

    bcp_subshell
    bcp_shlvl "bgmagenta"

    local host=""
    if [ -n "$container" ]; then
        # for toolbox
        if [ -r /run/.containerenv ]; then
            # This pulls the name= value from the file
            host=$(grep -oP '(?<=name=")[^"]+' /run/.containerenv | sed "s/fedora-toolbox-/F/")
            case "$host" in
                F44-rebuilt)  host="f45" ;;
                F45-hs)       host="f45-hs" ;;
                F44-branched) host="f44" ;;
                F43-haskell)  host="f43-hs" ;;
            esac
        else
            case "$VARIANT_ID" in
                eln)
                    host="$VARIANT_ID" ;;
                *)
                    host="$ID$VERSION_ID" ;;
            esac
        fi
        bcp_append "⬢$host" "$ANSI_COLOR;7;107"
        # ptyxis provides icon
        bcp_title "$host:\w"
    else
        bcp_title "\w"
    fi

    bcp_append "\w" "yellow;7;1"

    bcp_git_branch "" "bgmagenta;white" "yellow;bgmagenta"

    emacs_term_send_dir

    bcp_append "\$ " "default"
}

bcp_init

# PROMPT_END='${branch@P}\[$(emacs_term_prompt_end)\]'"\[$COL_RESET\]"

if [ -x "/usr/bin/zoxide" ]; then
    eval "$(zoxide init bash)"
fi
