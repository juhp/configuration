#!/bin/sh

TOOLBOX_PROG=/usr/bin/toolbox
#TOOLBOX_PROG=$HOME/src/toolbox/toolbox
#DISTROBOX_PROG=$HOME/src/distrobox/distrobox
DISTROBOX_PROG=/usr/bin/distrobox

if [ $# -eq 0 ]; then
    ARG=44
else
    ARG=$1
    shift
fi

if [ -z "$*" ]; then
    CMD=enter
else
    CMD=run
fi

case $ARG in
    44) CONTAINER=fedora-toolbox-44 ;;
    hs) CONTAINER=fedora-toolbox-44-haskell ;;
    43) CONTAINER=fedora-toolbox-43 ;;
    42) CONTAINER=fedora-toolbox-42 ;;
    41) CONTAINER=fedora-toolbox-41 ;;
    40) CONTAINER=fedora-toolbox-40 ;;
    39) CONTAINER=fedora-toolbox-39 ;;
    38) CONTAINER=fedora-toolbox-38 ;;
    37) CONTAINER=fedora-toolbox-37 ;;
    c8) CONTAINER=centos-toolbox-stream8 ;;
    c9) CONTAINER=centos-toolbox-stream9 ;;
    c10) CONTAINER=centos-toolbox-stream10 ;;
    el7) DISTROBOX=rhel7-distrobox ;;
    el8) CONTAINER=rhel-toolbox-8.10 ;;
    9) CONTAINER=rhel-toolbox-9.6 ;;
    10) CONTAINER=rhel-toolbox-10.0 ;;
    el9) CONTAINER=rhel-toolbox-9.6 ;;
    eln) CONTAINER=fedora-eln-toolbox ;;
    alpine) DISTROBOX=alpine ;;
    arch) CONTAINER=arch-toolbox-latest ;;
    debian) DISTROBOX=debian-distrobox ;;
    tumbleweed) DISTROBOX=tumbleweed-distrobox ;;
    ubuntu) CONTAINER=ubuntu-toolbox-25.04 ;;
    *-distrobox*) DISTROBOX=$ARG ;;
    *-toolbox*) CONTAINER=$ARG ;;
    *) DISTROBOX=$ARG-distrobox ;;
esac

if [ -n "$DISTROBOX" ]; then
    TOOLBOX=$DISTROBOX_PROG
    CNTOPT=name
    CONTAINER=$DISTROBOX
    echo $DISTROBOX
    if ! podman ps -a --format="{{.Names}}" | grep -q ^$DISTROBOX; then
        echo "not found"
        exit 1
    fi
else
    TOOLBOX=$TOOLBOX_PROG
    CNTOPT=container
fi

LANG=C.utf8

$TOOLBOX $CMD ${RELEASE:+--release $RELEASE}${CONTAINER:+--$CNTOPT $CONTAINER} $* || echo "$TOOLBOX $CMD ${RELEASE:+--release $RELEASE}${CONTAINER:+--$CNTOPT $CONTAINER} $*"
