(custom-set-variables
 ;; custom-set-variables was added by Custom.
 ;; If you edit it by hand, you could mess it up, so be careful.
 ;; Your init file should contain only one such instance.
 ;; If there is more than one, they won't work right.
 '(ansi-color-faces-vector
   [default default default italic underline success warning error])
 '(ansi-color-names-vector
   ["#242424" "#e5786d" "#95e454" "#cae682" "#8ac6f2" "#333366" "#ccaa8f"
    "#f6f3e8"])
 '(auth-source-save-behavior nil)
 '(column-number-mode t)
 '(eat-kill-buffer-on-exit t)
 '(fci-rule-color "#383838")
 '(frame-background-mode 'dark)
 '(fringe-mode 10 nil (fringe))
 '(git-ps1-mode-lighter-text-format " [%s]")
 '(grep-files-aliases
   '(("all" . "* .*") ("el" . "*.el") ("ch" . "*.[ch]") ("c" . "*.c")
     ("cc" . "*.cc *.cxx *.cpp *.C *.CC *.c++")
     ("cchh"
      . "*.cc *.[ch]xx *.[ch]pp *.[CHh] *.CC *.HH *.hh *.[ch]++")
     ("hh" . "*.hxx *.hpp *.[Hh] *.HH *.hh *.h++") ("h" . "*.h")
     ("l" . "[Cc]hange[Ll]og*") ("m" . "[Mm]akefile*")
     ("tex" . "*.tex") ("texi" . "*.texi") ("asm" . "*.[sS]")))
 '(hackernews-items-per-page 30)
 '(indicate-buffer-boundaries 'right)
 '(indicate-empty-lines t)
 '(linum-format " %6d ")
 '(magit-diff-options nil)
 '(magit-log-margin '(t "%Y-%m-%d %H:%M " magit-log-margin-width t 18))
 '(main-line-color1 "#222232")
 '(main-line-color2 "#333343")
 '(powerline-color1 "#222232")
 '(powerline-color2 "#333343")
 '(projectile-mode-line-prefix " Proj")
 '(show-paren-mode t)
 '(size-indication-mode t)
 '(user-mail-address "EMAIL@ADDRESS")
 '(vc-annotate-background nil)
 '(vc-annotate-color-map
   '((20 . "#d54e53") (40 . "goldenrod") (60 . "#e7c547")
     (80 . "DarkOliveGreen3") (100 . "#70c0b1") (120 . "DeepSkyBlue1")
     (140 . "#c397d8") (160 . "#d54e53") (180 . "goldenrod")
     (200 . "#e7c547") (220 . "DarkOliveGreen3") (240 . "#70c0b1")
     (260 . "DeepSkyBlue1") (280 . "#c397d8") (300 . "#d54e53")
     (320 . "goldenrod") (340 . "#e7c547") (360 . "DarkOliveGreen3")))
 '(vc-annotate-very-old-color nil)
 '(warning-suppress-types '((lsp-mode) (comp))))
